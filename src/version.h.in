#ifndef VERSION_H
#define VERSION_H

#include <string_view>

[[nodiscard]] constexpr inline std::string_view version() noexcept {
    const std::string release_mode = "@CMAKE_BUILD_TYPE@";

    constexpr std::string version_str = "Iris version: " + "@GIT_TAG@" + "\n"
              + "Compiled from commit: " + "@GIT_HASH@" + "\n"
              + "Compiled on date: " + "@COMPILE_DATE@" + "\n"
              + "Build type: "
              + (release_mode.empty ? "Default" : release_mode) + "\n";

    return version_str;

#endif // VERSION_H
