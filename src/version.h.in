#ifndef VERSION_H
#define VERSION_H

#include <string_view>

[[nodiscard]] constexpr inline std::string_view git_tag() noexcept {
    return "@GIT_TAG@";
}

[[nodiscard]] constexpr inline std::string_view git_hash() noexcept {
    return "@GIT_HASH@";
}

[[nodiscard]] constexpr inline std::string_view compile_date() noexcept {
    return "@COMPILE_DATE@";
}

[[nodiscard]] constexpr inline std::string_view release_mode() noexcept {
    return "@CMAKE_BUILD_TYPE@";
}

#endif // VERSION_H
